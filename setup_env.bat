@echo off
echo ================================================================================
echo СОЗДАНИЕ ВИРТУАЛЬНОГО ОКРУЖЕНИЯ
echo ================================================================================
echo.

echo 1. Создаем виртуальное окружение...
python -m venv .venv

echo.
echo 2. Активируем виртуальное окружение...
call .venv\Scripts\activate.bat

echo.
echo 3. Обновляем pip...
python -m pip install --upgrade pip

echo.
echo 4. Устанавливаем зависимости из requirements.txt...
pip install -r requirements.txt

echo.
echo ================================================================================
echo ГОТОВО!
echo ================================================================================
echo.
echo Виртуальное окружение создано и активировано.
echo.
echo Для активации в будущем используйте:
echo    .venv\Scripts\activate
echo.
echo Для деактивации:
echo    deactivate
echo.
pause
